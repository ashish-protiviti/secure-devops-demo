{
  "name": "leave-management-service",
  "version": "1.0.0",
  "description": "Demo microservice for GitHub Copilot + Secure DevOps showcase",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --testEnvironment=node",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.16.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js", "!src/vulnerable-example.js"]
  }
}
